#: src/pages/ChatPage.tsx
msgid "Slack bot token disconnected."
msgstr "Đã ngắt kết nối token bot Slack."

#: src/pages/ChatPage.tsx
msgid "Slack connected. Every hatchling can now post to the webhook's channel."
msgstr "Đã kết nối Slack. Giờ đây mỗi gà con đều có thể đăng vào kênh của webhook."

#: src/pages/ChatPage.tsx
msgid "Slack could not be reached. Check your connection and try again."
msgstr "Không thể kết nối tới Slack. Hãy kiểm tra mạng rồi thử lại."

#: src/pages/ChatPage.tsx
msgid "Slack disconnected."
msgstr "Đã ngắt kết nối Slack."

#: src/pages/ChatPage.tsx
msgid "Slack rejected that token. Reinstall the app in Slack, copy a fresh bot token, and try again."
msgstr "Slack đã từ chối token đó. Hãy cài lại ứng dụng trong Slack, sao chép token bot mới rồi thử lại."

